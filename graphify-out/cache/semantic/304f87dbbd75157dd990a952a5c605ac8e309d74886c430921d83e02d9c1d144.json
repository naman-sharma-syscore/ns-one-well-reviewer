{"nodes": [{"id": "design_system_overview_onewell_design_system", "label": "OneWELL Design System v1.0", "file_type": "document", "source_file": "codex/design-system/overview.md", "source_location": null, "source_url": null, "captured_at": "2026-04", "author": null, "contributor": null}, {"id": "design_system_overview_five_core_principles", "label": "Five Core Working Principles", "file_type": "rationale", "source_file": "codex/design-system/overview.md", "source_location": "lines 26-31", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "1) Use existing tokens never invent. 2) Brand marks are sacred. 3) Type pairing is fixed. 4) Cyan is the brand yes \u2014 one gradient CTA per view. 5) One canonical home per component. These enforce consistency and prevent design drift."}, {"id": "design_system_overview_anti_patterns", "label": "Design System Anti-Patterns", "file_type": "rationale", "source_file": "codex/design-system/overview.md", "source_location": "lines 52-61", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hardcoded hex, non-brand fonts, missing .ow-btn base class, multiple primary CTAs per view, concept colors on chrome, recolored seals, decorative emoji, bright gradients as text background, title-case headings, and generic error messages are all flagged in review."}, {"id": "design_system_overview_voice_tone", "label": "WELL Voice & Tone Guidelines", "file_type": "rationale", "source_file": "codex/design-system/overview.md", "source_location": "lines 68-87", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Calm, factual, generous, never alarmist. Sentence case for headings, title case for certification levels and proper nouns. Error format: what happened + next step. No urgency-baiting, no cheery error language."}, {"id": "design_system_overview_colors_and_type_css", "label": "colors_and_type.css \u2014 Design Tokens", "file_type